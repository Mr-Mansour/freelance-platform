{
  "name": "cybrion",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json}\"",
    "db:generate": "pnpm --filter @cybrion/database generate",
    "db:push": "pnpm --filter @cybrion/database push",
    "db:migrate": "pnpm --filter @cybrion/database migrate",
    "db:seed": "pnpm --filter @cybrion/database seed",
    "db:studio": "pnpm --filter @cybrion/database studio"
  },
  "dependencies": {
    "next": "^15.5.18",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cybrion/config": "workspace:*",
    "@cybrion/types": "workspace:*",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.5.2",
  "engines": {
    "node": ">=20.0.0"
  }
}
