generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  GUEST
  FREELANCER
  CLIENT
  MODERATOR
  ADMIN
  OWNER
}

enum TrustLevel {
  ROOKIE
  VERIFIED
  TRUSTED
  ELITE
  TITAN
  LEGENDARY
}

enum Availability {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum FreelancerAvailability {
  FULL_TIME
  PART_TIME
  HOURLY
}

enum BudgetType {
  FIXED
  HOURLY
}

enum ExperienceLevel {
  ENTRY
  INTERMEDIATE
  EXPERT
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  WITHDRAWN
}

enum ContractStatus {
  PENDING
  ACTIVE
  COMPLETED
  CANCELLED
  DISPUTED
}

enum EscrowStatus {
  UNFUNDED
  FUNDED
  RELEASED
  REFUNDED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  APPROVED
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
}

enum PaymentType {
  DEPOSIT
  WITHDRAWAL
  PAYMENT
  REFUND
  FEE
  PAYOUT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  FEATURED
  ARCHIVED
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum VerificationBadgeType {
  ID_VERIFIED
  SKILL_VERIFIED
  PORTFOLIO_VERIFIED
  ELITE
}

enum NotificationType {
  NEW_MESSAGE
  PROPOSAL_RECEIVED
  PROPOSAL_ACCEPTED
  PROPOSAL_REJECTED
  CONTRACT_STARTED
  MILESTONE_COMPLETED
  PAYMENT_RECEIVED
  REVIEW_RECEIVED
  JOB_MATCH
  ADMIN_ALERT
  VERIFICATION_UPDATE
  SYSTEM
}

model User {
  id                  String     @id @default(cuid())
  email               String     @unique
  username            String     @unique
  firstName           String
  lastName            String
  avatarUrl           String?
  role                UserRole   @default(GUEST)
  trustLevel          TrustLevel @default(ROOKIE)
  isVerified          Boolean    @default(false)
  isTwoFactorEnabled  Boolean    @default(false)
  isOnboarded         Boolean    @default(false)
  clerkId             String?    @unique
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  profile            UserProfile?
  freelancer         Freelancer?
  client             Client?
  sentMessages       Message[]        @relation("SentMessages")
  receivedMessages   Message[]        @relation("ReceivedMessages")
  reviewsGiven       Review[]         @relation("Reviewer")
  reviewsReceived    Review[]         @relation("Reviewee")
  notifications      Notification[]
  transactions       Transaction[]
  subscriptions      Subscription[]
  trustHistory       TrustEvent[]
  adminActions       AdminAction[]
  reports            Report[]
  chatParticipants   ChatParticipant[]

  @@map("users")
}

model UserProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  bio         String?
  title       String?
  location    String?
  website     String?
  hourlyRate  Float?
  availability Availability @default(AVAILABLE)
  languages   String[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Freelancer {
  id             String   @id @default(cuid())
  userId         String   @unique
  title          String?
  bio            String?
  hourlyRate     Float?
  availability   FreelancerAvailability @default(FULL_TIME)
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  jobSuccessRate Float    @default(0)
  completedJobs  Int      @default(0)
  totalEarned    Float    @default(0)
  trustScore     Float    @default(0)
  isVerified     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills         FreelancerSkill[]
  portfolios     Portfolio[]
  verificationBadges VerificationBadge[]
  proposals      Proposal[]
  contracts      Contract[]       @relation("FreelancerContracts")
  products       Product[]

  @@map("freelancers")
}

model FreelancerSkill {
  id              String @id @default(cuid())
  freelancerId    String
  name            String
  category        String
  proficiency     String @default("INTERMEDIATE")
  isVerified      Boolean @default(false)
  yearsExperience Float?

  freelancer Freelancer @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@map("freelancer_skills")
}

model Portfolio {
  id          String   @id @default(cuid())
  freelancerId String
  title       String
  description String?
  images      String[]
  url         String?
  category    String
  createdAt   DateTime @default(now())

  freelancer Freelancer @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@map("portfolios")
}

model VerificationBadge {
  id          String                @id @default(cuid())
  freelancerId String
  type        VerificationBadgeType
  issuedAt    DateTime              @default(now())
  expiresAt   DateTime?

  freelancer Freelancer @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@map("verification_badges")
}

model Client {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String?
  companySize     String?
  industry        String?
  totalSpent      Float    @default(0)
  jobsPosted      Int      @default(0)
  hireRate        Float    @default(0)
  rating          Float    @default(0)
  reviewCount     Int      @default(0)
  savedFreelancers String[]
  savedServices   String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs      Job[]
  contracts Contract[] @relation("ClientContracts")

  @@map("clients")
}

model Job {
  id              String         @id @default(cuid())
  clientId        String
  title           String
  description     String
  category        String
  skills          String[]
  budgetMin       Float
  budgetMax       Float
  budgetType      BudgetType     @default(FIXED)
  experienceLevel ExperienceLevel @default(INTERMEDIATE)
  duration        String?
  status          JobStatus      @default(OPEN)
  proposalsCount  Int            @default(0)
  averageBid      Float          @default(0)
  featured        Boolean        @default(false)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  proposals Proposal[]

  @@map("jobs")
}

model Proposal {
  id                String         @id @default(cuid())
  jobId             String
  freelancerId      String
  coverLetter       String
  bidAmount         Float
  estimatedDuration String?
  status            ProposalStatus @default(PENDING)
  isAiGenerated     Boolean        @default(false)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  job        Job        @relation(fields: [jobId], references: [id], onDelete: Cascade)
  freelancer Freelancer @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@map("proposals")
}

model Contract {
  id             String         @id @default(cuid())
  jobId          String?
  freelancerId   String
  clientId       String
  title          String
  description    String?
  amount         Float
  status         ContractStatus @default(PENDING)
  startDate      DateTime       @default(now())
  endDate        DateTime?
  escrowAmount   Float          @default(0)
  escrowStatus   EscrowStatus   @default(UNFUNDED)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  freelancer Freelancer @relation("FreelancerContracts", fields: [freelancerId], references: [id])
  client     Client     @relation("ClientContracts", fields: [clientId], references: [id])
  milestones Milestone[]
  reviews    Review[]

  @@map("contracts")
}

model Milestone {
  id          String           @id @default(cuid())
  contractId  String
  title       String
  description String?
  amount      Float
  status      MilestoneStatus  @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime         @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@map("milestones")
}

model Message {
  id          String      @id @default(cuid())
  senderId    String
  receiverId  String
  conversationId String?
  content     String
  messageType MessageType @default(TEXT)
  fileUrl     String?
  readAt      DateTime?
  createdAt   DateTime    @default(now())

  sender   User   @relation("SentMessages", fields: [senderId], references: [id])
  receiver User   @relation("ReceivedMessages", fields: [receiverId], references: [id])
  conversation ChatConversation? @relation(fields: [conversationId], references: [id])

  @@map("messages")
}

model ChatConversation {
  id            String   @id @default(cuid())
  contractId    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  messages     Message[]
  participants ChatParticipant[]

  @@map("chat_conversations")
}

model ChatParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime @default(now())
  joinedAt       DateTime @default(now())

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("chat_participants")
}

model Review {
  id          String   @id @default(cuid())
  contractId  String
  reviewerId  String
  revieweeId  String
  rating      Int
  content     String
  communication Int  @default(5)
  quality       Int  @default(5)
  professionalism Int @default(5)
  deadline      Int  @default(5)
  value         Int  @default(5)
  createdAt   DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  reviewer User     @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewee User     @relation("Reviewee", fields: [revieweeId], references: [id])

  @@map("reviews")
}

model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String
  icon     String?

  @@map("skills")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Transaction {
  id                   String        @id @default(cuid())
  userId               String
  type                 PaymentType
  amount               Float
  currency             String        @default("USD")
  status               PaymentStatus @default(PENDING)
  stripePaymentIntentId String?
  stripeTransferId      String?
  description          String?
  metadata             Json?
  createdAt            DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Product {
  id            String        @id @default(cuid())
  freelancerId  String
  title         String
  description   String
  price         Float
  category      String
  images        String[]
  status        ProductStatus @default(DRAFT)
  salesCount    Int           @default(0)
  rating        Float         @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  freelancer Freelancer @relation(fields: [freelancerId], references: [id], onDelete: Cascade)

  @@map("products")
}

model Category {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  icon        String?
  parentId    String?
  children    Category?  @relation("CategoryChildren", fields: [parentId], references: [id])
  parent      Category[] @relation("CategoryChildren")
  serviceCount Int       @default(0)

  @@map("categories")
}

model Subscription {
  id                    String             @id @default(cuid())
  userId                String
  plan                  SubscriptionPlan   @default(FREE)
  status                SubscriptionStatus @default(ACTIVE)
  currentPeriodStart    DateTime           @default(now())
  currentPeriodEnd      DateTime?
  stripeSubscriptionId  String?
  stripeCustomerId      String?
  advancedAnalytics     Boolean            @default(false)
  prioritySupport       Boolean            @default(false)
  customBranding        Boolean            @default(false)
  teamMembers           Int                @default(1)
  aiProposals           Boolean            @default(false)
  featuredListings      Boolean            @default(false)
  verificationBadge     Boolean            @default(false)
  apiAccess             Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model TrustEvent {
  id        String   @id @default(cuid())
  userId    String
  event     String
  scoreDelta Float
  reason    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("trust_events")
}

model AdminAction {
  id          String   @id @default(cuid())
  adminId     String
  action      String
  targetId    String
  targetType  String
  reason      String?
  details     Json?
  createdAt   DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])

  @@map("admin_actions")
}

model Report {
  id          String   @id @default(cuid())
  reporterId  String
  targetId    String
  targetType  String
  reason      String
  description String?
  status      String   @default("PENDING")
  resolvedBy  String?
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())

  reporter User @relation(fields: [reporterId], references: [id])

  @@map("reports")
}
